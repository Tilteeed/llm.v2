global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:
  # ----------------------------------------------------------
  # Метрики самого Prometheus.
  # ----------------------------------------------------------
  - job_name: prometheus
    static_configs:
      - targets:
          - "{{ monitoring_stack_prometheus_container_name }}:9090"

  # ----------------------------------------------------------
  # Node Exporter - метрики хоста:
  # CPU, RAM, disk, filesystem, network и т.д.
  # ----------------------------------------------------------
  - job_name: node_exporter
    static_configs:
      - targets:
          - "{{ monitoring_stack_node_exporter_container_name }}:9100"

  # ----------------------------------------------------------
  # cAdvisor - метрики Docker-контейнеров.
  # ----------------------------------------------------------
{% if monitoring_stack_enable_cadvisor %}
  - job_name: cadvisor
    static_configs:
      - targets:
          - "{{ monitoring_stack_cadvisor_container_name }}:8080"
{% endif %}

  # ----------------------------------------------------------
  # Ollama API.
  # Здесь пока просто проверка доступности через сам контейнер.
  # Полноценных Prometheus-метрик Ollama по умолчанию не дает,
  # но сам endpoint можно будет использовать позже через exporter.
  # ----------------------------------------------------------
  - job_name: ollama
    metrics_path: /metrics
    static_configs:
      - targets:
          - "{{ ollama_container_name }}:{{ ollama_container_internal_port }}"